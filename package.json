{
  "name": "watcherobot-workspace",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "status": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/status-all.ps1",
    "pull": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pull-all.ps1",
    "pull:fetch": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/pull-all.ps1 -FetchOnly",
    "skills:validate": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/validate-skills.ps1",
    "stm32": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/flash-stm32.ps1",
    "stm32:monitor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/monitor-stm32.ps1",
    "esp32:build": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-esp32.ps1",
    "esp32": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/flash-esp32.ps1",
    "esp32:monitor": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/monitor-esp32.ps1",
    "android": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/android-app.ps1",
    "app:start": "yarn --cwd WatcheRobot_app start",
    "app:android": "yarn --cwd WatcheRobot_app android",
    "app:ios": "yarn --cwd WatcheRobot_app ios",
    "app:lint": "yarn --cwd WatcheRobot_app lint",
    "app:test": "yarn --cwd WatcheRobot_app test",
    "desktop:dev": "npm --prefix \"WatcheRobot_client/Watcher Desktop App\" run dev",
    "desktop:server": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-server.ps1",
    "desktop:build": "npm --prefix \"WatcheRobot_client/Watcher Desktop App\" run build",
    "desktop:typecheck": "npm --prefix \"WatcheRobot_client/Watcher Desktop App\" run typecheck",
    "server": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-server.ps1",
    "server:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-server.ps1",
    "server:start:checked": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-server.ps1 -UseStartScript",
    "server:test": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-server.ps1",
    "ports": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/list-ports.ps1"
  }
}
